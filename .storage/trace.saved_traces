                      },
                      {
                        "condition": "template",
                        "value_template": "{{ states('sensor.izaans_room_temperature') | float(99) < states('input_number.vent_fan_heat_threshold') | int(21) }}\n"
                      }
                    ],
                    "sequence": [
                      {
                        "action": "fan.turn_on",
                        "target": {
