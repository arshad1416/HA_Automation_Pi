                      },
                      {
                        "condition": "template",
                        "value_template": "{{ states('sensor.izaans_room_temperature') | float(0) > states('input_number.vent_fan_cool_threshold') | int(23) }}\n"
                      }
                    ],
                    "sequence": [
                      {
                        "action": "fan.turn_on",
                        "target": {
                          "entity_id": "fan.izaan_s_room_20a970"
                        }
