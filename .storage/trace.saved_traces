          "config": {
            "id": "smart_vent_fan_control",
            "alias": "Smart Vent Fan Control",
            "description": "Unified vent fan control for Izaan and Mina. Heating + room < 21C -> fan ON. Cooling + room > 23C -> fan OFF. Idle or temp in range -> fan OFF. Re-evaluates every 10 min.",
            "mode": "restart",
            "triggers": [
              {
                "trigger": "state",
                "entity_id": "climate.ecobee",
                "attribute": "hvac_action",
                "id": "hvac_change"
              },
              {
                "trigger": "time_pattern",
                "minutes": "/10",
                "id": "periodic"
              }
