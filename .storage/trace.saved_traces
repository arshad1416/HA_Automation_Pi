              {
                "path": "trigger/0",
                "timestamp": "2026-06-23T13:00:10.743839+00:00",
                "changed_variables": {
                  "this": {
                    "entity_id": "automation.audit_log_all_cover_service_calls",
                    "state": "on",
                    "attributes": {
                      "id": "audit_cover_commands",
                      "last_triggered": "2026-06-23T13:00:10.295807+00:00",
                      "mode": "parallel",
                      "current": 0,
