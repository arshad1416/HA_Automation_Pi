            "action/13/then/0": [
              {
                "path": "action/13/then/0",
                "timestamp": "2026-06-23T04:23:59.617328+00:00",
                "result": {
                  "params": {
                    "domain": "notify",
                    "service": "mobile_app_cph2655",
                    "service_data": {
                      "message": "Climate AI: Set 21.5C cool - It is currently 00:23 during the ultra-low overnight utility rate period. Initiating summer pre-cooling by lowering the setpoint to 21.5C to shift energy load away from peak hours. Blinds remain unchanged as the sun is below the horizon. Vent boosters are set to the 30% maximum limit allowed during overnight hours (9PM-7AM).",
                      "title": "Climate AI"
