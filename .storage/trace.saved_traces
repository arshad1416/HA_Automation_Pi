            "start": "2026-06-23T13:00:00.134810+00:00",
            "finish": "2026-06-23T13:00:11.817940+00:00"
          },
          "domain": "automation",
          "item_id": "climate_ai_advisor",
          "trigger": "time pattern"
        }
      }
    ],
